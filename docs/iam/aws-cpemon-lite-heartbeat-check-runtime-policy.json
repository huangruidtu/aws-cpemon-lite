{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowScanTelemetryTable",
      "Effect": "Allow",
      "Action": [
        "dynamodb:Scan"
      ],
      "Resource": "arn:aws:dynamodb:*:*:table/aws-cpemon-lite-telemetry"
    },
    {
      "Sid": "AllowPublishHeartbeatMetric",
      "Effect": "Allow",
      "Action": [
        "cloudwatch:PutMetricData"
      ],
      "Resource": "*"
    }
  ]
}
